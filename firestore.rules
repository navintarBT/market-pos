rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────
    // Each user has { role, shopId? } — source of truth for permissions
    match /users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isControlAdmin());
      allow create: if isControlAdmin()
        || (
          isShopOwner(request.resource.data.shopId)
          && request.resource.data.role == 'staff'
          && request.resource.data.keys().hasAll(['role', 'shopId', 'email', 'displayName', 'createdAt'])
        )
        || (
          // Owner migrating their own account to a new uid (self email change)
          isShopOwner(request.resource.data.shopId)
          && request.resource.data.role == 'customer'
          && request.resource.data.keys().hasAll(['role', 'shopId', 'email', 'createdAt'])
        );
      allow update: if isControlAdmin()
        || (
          isShopOwner(resource.data.shopId)
          && resource.data.role == 'staff'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'updatedAt'])
        );
      allow delete: if isControlAdmin()
        || (
          isShopOwner(resource.data.shopId)
          && resource.data.role == 'staff'
        )
        || (
          // Owner deleting their own old doc after an email change
          uid == request.auth.uid
          && resource.data.role == 'customer'
        );
    }

    // ── Customers (personal info, control panel only) ─────────────────────
    match /customers/{customerId} {
      allow read:   if isControlAdmin();
      allow create: if isControlAdmin();
      allow update: if isControlAdmin();
      allow delete: if false;

      match /payments/{paymentId} {
        allow read:   if isControlAdmin();
        allow create: if isControlAdmin();
        allow update: if isControlAdmin();
        allow delete: if isControlAdmin();
      }
    }

    // ── Packages (Control Panel only) ────────────────────────────────────
    match /packages/{packageId} {
      allow read:   if isControlAdmin();
      allow create: if isControlAdmin();
      allow update: if isControlAdmin();
      allow delete: if isControlAdmin();
    }

    // ── Tenants (Control Panel) ───────────────────────────────────────────
    match /tenants/{tenantId} {
      allow read: if isControlAdmin() || isShopMember(tenantId);
      allow write: if isControlAdmin();

      match /invoices/{invoiceId} {
        allow read: if isControlAdmin();
        allow write: if isControlAdmin();
      }
    }

    // ── Shops ─────────────────────────────────────────────────────────────
    match /shops/{shopId} {
      allow read: if isControlAdmin() || isShopMember(shopId);
      allow create, delete: if isControlAdmin();
      allow update: if isControlAdmin() || (
        isShopOwner(shopId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'profileUrl', 'updatedAt'])
        && request.resource.data.name is string
        && (
          !('profileUrl' in request.resource.data)
          || request.resource.data.profileUrl is string
        )
      );

      match /products/{productId} {
        allow read:           if isControlAdmin() || isShopMember(shopId);
        allow create, update: if isShopOwner(shopId);
        allow delete:         if isShopOwner(shopId);
      }

      match /sales/{saleId} {
        allow read:   if isControlAdmin() || isShopMember(shopId);
        allow create: if isShopMember(shopId) && validSale(request.resource.data);
        allow update: if false;
        allow delete: if isControlAdmin()
          || isShopOwner(shopId)
          || (isShopMember(shopId) && hasStaffPermission(shopId, 'canDeleteSales'));
      }

      match /expenses/{expenseId} {
        allow read:   if isControlAdmin() || isShopMember(shopId);
        allow create: if isShopMember(shopId)
          && request.resource.data.keys().hasAll(['description', 'amount', 'createdAt'])
          && request.resource.data.amount is number
          && request.resource.data.amount > 0;
        allow update: if isShopOwner(shopId)
          && request.resource.data.keys().hasAll(['description', 'amount'])
          && request.resource.data.amount is number
          && request.resource.data.amount > 0;
        allow delete: if isShopOwner(shopId);
      }

      match /categories/{categoryId} {
        allow read:   if isControlAdmin() || isShopMember(shopId);
        allow create: if isShopOwner(shopId)
          && request.resource.data.keys().hasAll(['name'])
          && request.resource.data.name is string;
        allow update: if isShopOwner(shopId) && request.resource.data.name is string;
        allow delete: if isShopOwner(shopId);
      }

      match /bundles/{bundleId} {
        allow read:           if isControlAdmin() || isShopMember(shopId);
        allow create, update: if isShopOwner(shopId);
        allow delete:         if isShopOwner(shopId);
      }

      match /returns/{returnId} {
        allow read:           if isControlAdmin() || isShopMember(shopId);
        allow create:         if isShopOwner(shopId) && validReturn(request.resource.data);
        allow update, delete: if false;
      }

      match /users/{uid} {
        allow read:  if isControlAdmin() || isShopMember(shopId);
        allow write: if isControlAdmin() || isShopOwner(shopId);
      }

      match /transfers/{transferId} {
        allow read:          if isControlAdmin() || isShopMember(shopId);
        allow create:        if isShopOwner(shopId);
        allow update, delete: if false;
      }
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return request.auth != null && getUserData().role == 'superadmin';
    }

    function isControlAdmin() {
      return request.auth != null
        && getUserData().role in ['superadmin', 'admin'];
    }

    function isShopMember(shopId) {
      let d = getUserData();
      return request.auth != null
        && d.shopId == shopId
        && d.role in ['customer', 'staff'];
    }

    function isShopOwner(shopId) {
      let d = getUserData();
      return request.auth != null
        && d.shopId == shopId
        && d.role == 'customer';
    }

    function hasStaffPermission(shopId, key) {
      return request.auth != null
        && exists(/databases/$(database)/documents/shops/$(shopId)/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/shops/$(shopId)/users/$(request.auth.uid)).data.permissions[key] == true;
    }

    function validSale(data) {
      return data.keys().hasAll(['items', 'total', 'paymentType', 'createdAt'])
        && data.total is number
        && data.total > 0
        && (data.paymentType == 'cash' || data.paymentType == 'qr');
    }

    function validReturn(data) {
      return data.keys().hasAll([
          'productId', 'productName', 'variantSize', 'variantColor',
          'quantity', 'costPrice', 'sellingPrice', 'createdAt'
        ])
        && data.quantity is int
        && data.quantity > 0
        && data.costPrice is number
        && data.costPrice >= 0
        && data.sellingPrice is number
        && data.sellingPrice >= 0
        && data.productId is string
        && data.productName is string;
    }
  }
}
